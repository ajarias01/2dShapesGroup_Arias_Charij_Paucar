        /// <summary>
        /// Abre el formulario de una figura específica.
        /// </summary>
        private void OpenShapeForm(string shapeName)
        {
            try
            {
                FrmAllShapes form = new FrmAllShapes(shapeName);
                form.ShowDialog();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error al abrir la figura: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

