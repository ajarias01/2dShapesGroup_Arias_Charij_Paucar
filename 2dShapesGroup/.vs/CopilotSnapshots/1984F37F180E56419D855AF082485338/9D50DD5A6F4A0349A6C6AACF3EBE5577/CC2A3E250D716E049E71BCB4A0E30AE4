        private void OpenShape(string shapeName)
        {
            pnlMain.Visible = false;

            FrmAllShapes activeFrm = null;
            foreach (Form f in this.MdiChildren)
            {
                if (f is FrmAllShapes)
                {
                    activeFrm = (FrmAllShapes)f;
                    f.Activate();
                    break;
                }
            }

            if (activeFrm == null)
            {
                activeFrm = new FrmAllShapes();
                activeFrm.MdiParent = this;
                activeFrm.Show();
                activeFrm.WindowState = FormWindowState.Maximized;
            }

            activeFrm.LoadShape(shapeName);
        }

