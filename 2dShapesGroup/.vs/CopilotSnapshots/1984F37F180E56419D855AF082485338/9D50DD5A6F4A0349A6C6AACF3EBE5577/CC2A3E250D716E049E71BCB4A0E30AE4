        private void TsmiShapes_Click(object sender, EventArgs e)
        {
            if (this.Controls.Find("pnlMain", true).Length > 0)
                this.Controls.Find("pnlMain", true)[0].Visible = false; // Hide the info panel

            // Check if FrmAllShapes is already open
            foreach (Form f in this.MdiChildren)
            {
                if (f is _2dShapesGroup.Forms.FrmAllShapes)
                {
                    f.Activate();
                    return;
                }
            }

            // Open FrmAllShapes inside FrmHome
            var frm = new _2dShapesGroup.Forms.FrmAllShapes();
            frm.MdiParent = this;
            frm.Show();
            frm.WindowState = FormWindowState.Maximized;
        }

        private void basicPolygonsToolStripMenuItem_Click(object sender, EventArgs e) { }
        private void irregularShapesToolStripMenuItem_Click(object sender, EventArgs e) { }

        // Dummy handlers to satisfy the designer
