using System;
using System.Collections.Generic;
using System.Windows.Forms;
using _2dShapesGroup.Interfaces;
using _2dShapesGroup.Models;

namespace _2dShapesGroup.Forms
{
    /// <summary>
    /// Home form — navigation hub.
    /// Single Responsibility: only handles navigation between shapes.
    /// Open/Closed: adding a new group to ShapeRegistry automatically appears here.
    /// </summary>
    public partial class FrmHome : Form
    {
        // ── Constructor ───────────────────────────────────────────────────
        public FrmHome()
        {
            InitializeComponent();   // generated by the designer
            tsmiShapes.Click += TsmiShapes_Click;
        }

        private void TsmiShapes_Click(object sender, EventArgs e)
        {
            pnlMain.Visible = false; // Hide the info panel

            // Check if FrmAllShapes is already open
            foreach (Form f in this.MdiChildren)
            {
                if (f is FrmAllShapes)
                {
                    f.Activate();
                    return;
                }
            }

            // Open FrmAllShapes inside FrmHome
            var frm = new FrmAllShapes();
            frm.MdiParent = this;
            frm.Show();
            frm.WindowState = FormWindowState.Maximized;
        }

        // ── Exit menu event ───────────────────────────────────────────────
        private void tsmiExit_Click(object sender, EventArgs e)
        {
            Application.Exit();
        }

        private void FrmHome_Load(object sender, EventArgs e)
        {

        }
    }
}
