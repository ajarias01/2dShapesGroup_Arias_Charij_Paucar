    /// <summary>
    /// Pentágono: Polígono regular de 5 lados.
    /// Perímetro = 5 * lado
    /// Área = (5 * lado²) / (4 * tan(π/5))
    /// </summary>
    public class Pentagon : ISpecialShape
    {
        public string Name => "Pentágono";
        public IReadOnlyList<(string Label, double DefaultValue)> Parameters => new[] { ("Lado", 80.0) };

        public double Perimeter(double[] v) => 5 * v[0];
        public double Area(double[] v) => v[0] * v[0] / 4 * Math.Sqrt(5 * (5 + 2 * Math.Sqrt(5)));

        public void Draw(System.Drawing.Graphics g, RectangleF bounds, double[] v)
        {
            ShapesApp.Models.BasicPolygons.Pentagon.DrawRegularPolygon(g, bounds, 5);
        }
        
        public List<string> GetInputLabels() => new List<string> { "Lado" };
        public void SetParameters(double[] parameters) {}
        public double CalculatePerimeter() => 0;
        public double CalculateArea() => 0;
        public void Draw(System.Drawing.Graphics g, System.Drawing.Rectangle bounds, System.Drawing.Brush fillBrush, System.Drawing.Pen pen) {}
    }

