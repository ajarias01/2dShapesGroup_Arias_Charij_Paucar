    /// <summary>
    /// Rombo: Cuadrilátero con todos los lados iguales.
    /// Perímetro = 4 * lado
    /// Área = (d1 * d2) / 2 [d1, d2 = diagonales]
    /// </summary>
    public class Rhombus : ISpecialShape
    {
        public string Name => "Rombo";
        public IReadOnlyList<(string Label, double DefaultValue)> Parameters => new[] { ("Diagonal d1", 100.0), ("Diagonal d2", 70.0) };

        public double Perimeter(double[] v) => 2 * Math.Sqrt(v[0] * v[0] + v[1] * v[1]);
        public double Area(double[] v) => v[0] * v[1] / 2;

        public void Draw(System.Drawing.Graphics g, RectangleF bounds, double[] v)
        {
            ShapeGraphicsHelper.ApplyHighQuality(g);
            float d1 = (float)v[0], d2 = (float)v[1];
            RectangleF r = ShapeGraphicsHelper.PaddedRect(bounds, d1, d2);
            float cx = r.X + r.Width / 2f;
            float cy = r.Y + r.Height / 2f;

            PointF[] pts =
            {
                new(cx,          r.Y),            // top
                new(r.X + r.Width, cy),           // right
                new(cx,          r.Y + r.Height), // bottom
                new(r.X,         cy)              // left
            };

            using var brush = ShapeGraphicsHelper.CreateFillBrush();
            using var pen   = ShapeGraphicsHelper.CreateBorderPen();
            g.FillPolygon(brush, pts);
            g.DrawPolygon(pen, pts);
        }
        
        public List<string> GetInputLabels() => new List<string> { "Diagonal 1", "Diagonal 2" };
        public void SetParameters(double[] parameters) {}
        public double CalculatePerimeter() => 0;
        public double CalculateArea() => 0;
        public void Draw(System.Drawing.Graphics g, System.Drawing.Rectangle bounds, System.Drawing.Brush fillBrush, System.Drawing.Pen pen) {}
    }

    /// <summary>
    /// Sector Circular (Pie): Sector de un círculo.
    /// Perímetro = 2r + arco = 2r + rθ (donde θ en radianes)
    /// Área = r²θ / 2 (donde θ en radianes)
    /// </summary>
    public class PieSector : ISpecialShape
    {
        public string Name => "Sector Circular";
        public IReadOnlyList<(string Label, double DefaultValue)> Parameters => new[] { ("Radius (r)", 70.0), ("Angle θ (°)", 120.0) };

        public double Perimeter(double[] v)
        {
            double rad = v[1] * Math.PI / 180;
            return 2 * v[0] + v[0] * rad;
        }
        public double Area(double[] v)
        {
            double rad = v[1] * Math.PI / 180;
            return v[0] * v[0] * rad / 2;
        }

        public void Draw(System.Drawing.Graphics g, RectangleF bounds, double[] v)
        {
            ShapeGraphicsHelper.ApplyHighQuality(g);
            RectangleF sq = ShapeGraphicsHelper.PaddedSquare(bounds);
            using var brush = ShapeGraphicsHelper.CreateFillBrush();
            using var pen   = ShapeGraphicsHelper.CreateBorderPen();
            // Start at top (-90°) so the sector opens downward/rightward nicely
            float sweep = (float)Math.Min(v[1], 359.9);
            g.FillPie(brush, sq.X, sq.Y, sq.Width, sq.Height, -90f, sweep);
            g.DrawPie(pen,   sq.X, sq.Y, sq.Width, sq.Height, -90f, sweep);
        }
        
        public List<string> GetInputLabels() => new List<string> { "Radio", "Ángulo (grados)" };
        public void SetParameters(double[] parameters) {}
        public double CalculatePerimeter() => 0;
        public double CalculateArea() => 0;
        public void Draw(System.Drawing.Graphics g, System.Drawing.Rectangle bounds, System.Drawing.Brush fillBrush, System.Drawing.Pen pen) {}
    }

    /// <summary>
    /// Trébol: Forma combinada de círculos (3 hojas).
    /// Perímetro = suma de arcos circulares
    /// Área = suma de segmentos circulares
    /// </summary>
    public class Trefoil : ISpecialShape
    {
        public string Name => "Trébol";
        public IReadOnlyList<(string Label, double DefaultValue)> Parameters => new[] { ("Lobe radius r", 40.0) };

        public double Perimeter(double[] v) => 3 * 2 * Math.PI * v[0];
        public double Area(double[] v) => 3 * Math.PI * v[0] * v[0];

        public void Draw(System.Drawing.Graphics g, RectangleF bounds, double[] v)
        {
            ShapeGraphicsHelper.ApplyHighQuality(g);
            float r   = (float)v[0];
            float sq  = Math.Min(bounds.Width, bounds.Height) - 24;
            // Each lobe circle fits within half the square
            float scale = sq / (r * 4);
            float rs  = r * scale;   // scaled lobe radius
            float cx  = bounds.X + bounds.Width  / 2f;
            float cy  = bounds.Y + bounds.Height / 2f;

            using var brush = ShapeGraphicsHelper.CreateFillBrush();
            using var pen   = ShapeGraphicsHelper.CreateBorderPen();

            // Three lobes at 90°, 210°, 330° (top, bottom-left, bottom-right)
            double[] angles = { -Math.PI / 2, -Math.PI / 2 + 2 * Math.PI / 3, -Math.PI / 2 + 4 * Math.PI / 3 };
            foreach (double angle in angles)
            {
                float lx = cx + (float)(rs * Math.Cos(angle)) - rs;
                float ly = cy + (float)(rs * Math.Sin(angle)) - rs;
                g.FillEllipse(brush, lx, ly, rs * 2, rs * 2);
                g.DrawEllipse(pen,   lx, ly, rs * 2, rs * 2);
            }
        }
        
        public List<string> GetInputLabels() => new List<string> { "Radio" };
        public void SetParameters(double[] parameters) {}
        public double CalculatePerimeter() => 0;
        public double CalculateArea() => 0;
        public void Draw(System.Drawing.Graphics g, System.Drawing.Rectangle bounds, System.Drawing.Brush fillBrush, System.Drawing.Pen pen) {}
    }

    /// <summary>
    /// Corazón: Forma de corazón using Curvas Bézier.
    /// Perímetro = cálculo numérico
    /// Área = cálculo numérico basado en Bézier
    /// </summary>
    public class Heart : ISpecialShape
    {
        public string Name => "Corazón";
        public IReadOnlyList<(string Label, double DefaultValue)> Parameters => new[] { ("Tamaño", 100.0) };

        public double Perimeter(double[] v) => v[0] * 5.1; // Aproximación
        public double Area(double[] v) => v[0] * v[0] * 0.7; // Aproximación

        public void Draw(System.Drawing.Graphics g, RectangleF bounds, double[] v)
        {
            ShapeGraphicsHelper.ApplyHighQuality(g);
            float size = (float)v[0];
            RectangleF r = ShapeGraphicsHelper.PaddedRect(bounds, size, size);
            
            float cx = r.X + r.Width / 2f;
            float cy = r.Y + r.Height / 2f;
            float w = r.Width / 2f;
            float h = r.Height / 2f;

            PointF[] pts =
            {
                new PointF(cx, cy + h * 0.6f), // Bottom
                new PointF(cx - w, cy - h * 0.4f), // Left
                new PointF(cx - w * 0.4f, cy - h), // Top Left
                new PointF(cx, cy - h * 0.2f), // Top Center
                new PointF(cx + w * 0.4f, cy - h), // Top Right
                new PointF(cx + w, cy - h * 0.4f), // Right
            };

            using var path = new System.Drawing.Drawing2D.GraphicsPath();
            path.AddBeziers(new PointF[] { pts[0], pts[1], pts[2], pts[3] });
            path.AddBeziers(new PointF[] { pts[3], pts[4], pts[5], pts[0] });

            using var brush = ShapeGraphicsHelper.CreateFillBrush();
            using var pen   = ShapeGraphicsHelper.CreateBorderPen();
            g.FillPath(brush, path);
            g.DrawPath(pen, path);
        }
        
        public List<string> GetInputLabels() => new List<string> { "Tamaño" };
        public void SetParameters(double[] parameters) {}
        public double CalculatePerimeter() => 0;
        public double CalculateArea() => 0;
        public void Draw(System.Drawing.Graphics g, System.Drawing.Rectangle bounds, System.Drawing.Brush fillBrush, System.Drawing.Pen pen) {}
    }
