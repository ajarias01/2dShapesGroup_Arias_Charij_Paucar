using System;
using System.Drawing;
using System.Drawing.Drawing2D;

namespace _2dShapesGroup.Graphics
{
    /// <summary>
    /// Helper centralizado para operaciones gráficas.
    /// Proporciona fábricas de pinceles, plumas y métodos de utilidad para dibujo.
    /// </summary>
    public static class ShapeGraphicsHelper
    {
        /// <summary>
        /// Crea un pincel sólido con el color especificado.
        /// </summary>
        public static SolidBrush CreateSolidBrush(Color color)
        {
            return new SolidBrush(color);
        }

        /// <summary>
        /// Crea un pincel con gradiente lineal.
        /// </summary>
        public static LinearGradientBrush CreateLinearGradient(
            Rectangle rect,
            Color startColor,
            Color endColor,
            float angle = 0f)
        {
            var brush = new LinearGradientBrush(rect, startColor, endColor, angle);
            return brush;
        }

        /// <summary>
        /// Crea una pluma con el color y ancho especificados.
        /// </summary>
        public static Pen CreatePen(Color color, float width = 2f)
        {
            var pen = new Pen(color, width)
            {
                LineJoin = LineJoin.Round,
                EndCap = LineCap.Round
            };
            return pen;
        }

        // ── Helper Graphics methods ───────────────────────────────────────
        /// <summary>
        /// Habilita el suavizado (anti-alias) en el contexto gráfico.
        /// </summary>
        public static void EnableAntiAlias(System.Drawing.Graphics g)
        {
            g.SmoothingMode = SmoothingMode.AntiAlias;
        }

        /// <summary>
        /// Aplica configuración de alta calidad al contexto gráfico (anti-alias).
        /// </summary>
        public static void ApplyHighQuality(System.Drawing.Graphics g)
        {
            g.SmoothingMode = SmoothingMode.AntiAlias;
            g.TextRenderingHint = System.Drawing.Text.TextRenderingHint.AntiAlias;
            g.InterpolationMode = InterpolationMode.HighQualityBicubic;
        }

        /// <summary>
        /// Crea un pincel sólido con un color de relleno predeterminado.
        /// </summary>
        public static SolidBrush CreateFillBrush()
        {
            return new SolidBrush(Color.FromArgb(173, 216, 230)); // azul claro
        }

        /// <summary>
        /// Crea una pluma con un color de borde predeterminado.
        /// </summary>
        public static Pen CreateBorderPen()
        {
            return new Pen(Color.FromArgb(0, 0, 139), 2f); // azul oscuro, 2px
        }

        /// <summary>
        /// Ajusta un rectángulo para ser cuadrado dentro de los límites, centrado.
        /// Con un relleno adicional.
        /// </summary>
        public static RectangleF PaddedSquare(RectangleF b)
        {
            float side = Math.Min(b.Width, b.Height) - 24;
            return new RectangleF(b.X + (b.Width - side) / 2f,
                                  b.Y + (b.Height - side) / 2f, side, side);
        }

        /// <summary>
        /// Ajusta un rectángulo para que la figura quepa centrada dentro de los límites.
        /// Con un relleno adicional.
        /// </summary>
        public static RectangleF PaddedRect(RectangleF b, float w, float h)
        {
            float scale = Math.Min((b.Width - 24) / w, (b.Height - 24) / h);
            float rw = w * scale;
            float rh = h * scale;
            return new RectangleF(b.X + (b.Width - rw) / 2f,
                                  b.Y + (b.Height - rh) / 2f, rw, rh);
        }

        /// <summary>
        /// Ajusta un rectángulo para que la figura quepa centrada dentro de los límites.
        /// </summary>
        public static Rectangle FitCentered(Rectangle bounds, float aspectRatio)
        {
            float boundsAspect = (float)bounds.Width / bounds.Height;
            Rectangle result;

            if (boundsAspect > aspectRatio)
            {
                int height = bounds.Height;
                int width = (int)(height * aspectRatio);
                int x = bounds.X + (bounds.Width - width) / 2;
                result = new Rectangle(x, bounds.Y, width, height);
            }
            else
            {
                int width = bounds.Width;
                int height = (int)(width / aspectRatio);
                int y = bounds.Y + (bounds.Height - height) / 2;
                result = new Rectangle(bounds.X, y, width, height);
            }

            return result;
        }

        /// <summary>
        /// Aclara un color en porcentaje.
        /// </summary>
        public static Color Lighten(Color color, float percent)
        {
            percent = Math.Max(0, Math.Min(1, percent));
            return Color.FromArgb(
                color.A,
                (int)Math.Min(255, color.R + (255 - color.R) * percent),
                (int)Math.Min(255, color.G + (255 - color.G) * percent),
                (int)Math.Min(255, color.B + (255 - color.B) * percent)
            );
        }

        /// <summary>
        /// Oscurece un color en porcentaje.
        /// </summary>
        public static Color Darken(Color color, float percent)
        {
            percent = Math.Max(0, Math.Min(1, percent));
            return Color.FromArgb(
                color.A,
                (int)(color.R * (1 - percent)),
                (int)(color.G * (1 - percent)),
                (int)(color.B * (1 - percent))
            );
        }

        /// <summary>
        /// Rellena y dibuja el contorno de un camino.
        /// </summary>
        public static void FillAndStrokePath(
            System.Drawing.Graphics g,
            GraphicsPath path,
            Brush fillBrush,
            Pen outlinePen)
        {
            if (fillBrush != null)
                g.FillPath(fillBrush, path);

            if (outlinePen != null)
                g.DrawPath(outlinePen, path);
        }
    }
}
