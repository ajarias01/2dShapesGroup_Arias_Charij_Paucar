using System;
using System.Collections.Generic;
using System.Windows.Forms;
using _2dShapesGroup.Interfaces;
using _2dShapesGroup.Models;
using ShapesApp.Models;

namespace ShapesApp.Forms
{
    /// <summary>
    /// Home form — navigation hub.
    /// Single Responsibility: only handles navigation between shapes.
    /// Open/Closed: adding a new group to ShapeRegistry automatically appears here.
    /// </summary>
    public partial class FrmHome : Form
    {
        // ── Constructor ───────────────────────────────────────────────────
        public FrmHome()
        {
            InitializeComponent();   // generated by the designer (FrmHome.Designer.cs)
            BuildShapesMenu();       // dynamic menu logic
        }

        // ── Builds Shapes → Group → Shape items dynamically ──────────────
        private void BuildShapesMenu()
        {
            var registry = ShapeRegistry.GetAll();

            foreach (var kvp in registry)
            {
                string groupName = kvp.Key;
                List<IShape> shapes = kvp.Value;

                // Sub-menu per group (e.g. "Basic Polygons")
                var groupItem = new ToolStripMenuItem(groupName);

                foreach (IShape shape in shapes)
                {
                    var shapeItem = new ToolStripMenuItem(shape.Name);

                    // Capture the Type to instantiate fresh on click
                    Type shapeType = shape.GetType();
                    shapeItem.Click += (s, e) => OpenShapeForm(shapeType);

                    groupItem.DropDownItems.Add(shapeItem);
                }

                tsmiShapes.DropDownItems.Add(groupItem);
            }

            // Separator + full gallery
            tsmiShapes.DropDownItems.Add(new ToolStripSeparator());

            var galleryItem = new ToolStripMenuItem("All Shapes Gallery…");
            galleryItem.Click += (s, e) => new FrmAllShapes().Show();
            tsmiShapes.DropDownItems.Add(galleryItem);
        }

        // ── Opens FrmAllShapes pre-selected on the chosen shape ───────────
        private void OpenShapeForm(Type shapeType)
        {
            IShape instance = (IShape)Activator.CreateInstance(shapeType)!;
            var frm = new FrmAllShapes();
            frm.SelectShape(instance);
            frm.Show();
        }

        // ── Exit menu event ───────────────────────────────────────────────
        private void tsmiExit_Click(object sender, EventArgs e)
        {
            Application.Exit();
        }

        private void FrmHome_Load(object sender, EventArgs e)
        {

        }
    }
}
